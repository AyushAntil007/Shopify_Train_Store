{% if section.settings.show %}
  <div class="announcement">{{ section.settings.text }}</div>
{% endif %}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    { "type": "checkbox", "id": "show", "label": "Show bar", "default": true },
    { "type": "text", "id": "text", "label": "Message", "default": "Free shipping over $50 | Use code WELCOME10" }
  ]
}
{% endschema %}

<section class="section">
  <div class="container">
    <h2 class="section-title">{{ section.settings.heading }}</h2>
    <div class="grid grid--3">
      {% for block in section.blocks %}
        <article class="card usp" {{ block.shopify_attributes }}>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "USP benefits",
  "settings": [{ "type": "text", "id": "heading", "label": "Heading", "default": "Why customers trust us" }],
  "blocks": [
    { "type": "benefit", "name": "Benefit", "settings": [
      { "type": "text", "id": "title", "label": "Title", "default": "Dermatologist tested" },
      { "type": "textarea", "id": "text", "label": "Text", "default": "Gentle formulas designed for daily use." }
    ]}
  ],
  "max_blocks": 3,
  "presets": [{ "name": "USP benefits", "blocks": [{ "type": "benefit" }, { "type": "benefit" }, { "type": "benefit" }] }]
}
{% endschema %}

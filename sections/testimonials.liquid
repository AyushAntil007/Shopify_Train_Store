<section class="section">
  <div class="container">
    <h2 class="section-title">{{ section.settings.heading }}</h2>
    <div class="grid grid--3">
      {% for block in section.blocks %}
        <article class="card testimonial" {{ block.shopify_attributes }}>
          <p>“{{ block.settings.quote }}”</p>
          <strong>— {{ block.settings.author }}</strong>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [{ "type": "text", "id": "heading", "label": "Heading", "default": "Loved by real customers" }],
  "blocks": [
    { "type": "review", "name": "Review", "settings": [
      { "type": "textarea", "id": "quote", "label": "Quote", "default": "My skin feels calmer within one week." },
      { "type": "text", "id": "author", "label": "Author", "default": "Ayesha K." }
    ]}
  ],
  "max_blocks": 3,
  "presets": [{ "name": "Testimonials", "blocks": [{ "type": "review" }, { "type": "review" }, { "type": "review" }] }]
}
{% endschema %}

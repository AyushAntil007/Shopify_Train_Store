<section class="section">
  <div class="container newsletter section">
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.copy }}</p>
    {% form 'customer' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input type="email" name="contact[email]" placeholder="Enter your email" required>
      <button class="btn" type="submit">{{ section.settings.button_label }}</button>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter signup",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get skincare tips + exclusive offers" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Subscribe and receive 10% off your first order." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Subscribe" }
  ],
  "presets": [{ "name": "Newsletter signup" }]
}
{% endschema %}
